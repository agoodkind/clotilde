# Copy to notarize.env for local releases.
# notarize.env is gitignored and should contain only op:// references.
#
# GitHub Actions resolves the same values through the read-only
# 1Password service account stored in the OP_SERVICE_ACCOUNT_TOKEN
# repository secret.

MACOS_SIGN_P12=op://CI/macOS Release Signing and Notarization CI/macos_sign_p12_single
MACOS_SIGN_PASSWORD=op://CI/macOS Release Signing and Notarization CI/MACOS_SIGN_PASSWORD
MACOS_NOTARY_KEY=op://CI/macOS Release Signing and Notarization CI/MACOS_NOTARY_KEY
MACOS_NOTARY_KEY_ID=op://CI/macOS Release Signing and Notarization CI/MACOS_NOTARY_KEY_ID
MACOS_NOTARY_ISSUER_ID=op://CI/macOS Release Signing and Notarization CI/MACOS_NOTARY_ISSUER_ID
